# Copy this file to `.env` (never commit .env) and fill in the values.

# Password to access /admin. Any long, random string works.
ADMIN_PASSWORD=OK-webstudio-admin-2026

# --- Contact form notifications (optional but recommended) ----------------
# Telegram Bot API — create a bot via @BotFather and get its token.
TELEGRAMM_TOKEN=
# Numeric chat id that receives the notification (your own user id).
TELEGRAMM_ID=

# Resend.com — API key for transactional email.
RESEND_API_KEY=

# --- GitHub-backed CMS (required in production) ---------------------------
# Fine-grained Personal Access Token with `Contents: Read & write` on THIS repo.
# Create at: https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=
GITHUB_REPO_OWNER=okcompany
GITHUB_REPO_NAME=web-studio
GITHUB_REPO_BRANCH=main

# --- Vercel build hint ----------------------------------------------------
# Needed for Vercel to pass --legacy-peer-deps through to npm install.
NPM_CONFIG_LEGACY_PEER_DEPS=true
